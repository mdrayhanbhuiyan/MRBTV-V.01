<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer TV frame with a gorgeous neon green sport gradient -->
    <path
        android:pathData="M18,32 C18,28.7 20.7,26 24,26 L84,26 C87.3,26 90,28.7 90,32 L90,68 C90,71.3 87.3,74 84,74 L24,74 C20.7,74 18,71.3 18,68 Z"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="26"
                android:endX="90"
                android:endY="74"
                android:type="linear">
                <item android:color="#00E676" android:offset="0.0"/>
                <item android:color="#00C853" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- TV Stand in Neon Green -->
    <path
        android:pathData="M46,74 L62,74 L62,82 L46,82 Z"
        android:fillColor="#00E676" />

    <!-- TV Base in Emerald -->
    <path
        android:pathData="M34,82 L74,82 L74,86 L34,86 Z"
        android:fillColor="#00C853" />

    <!-- Antennas -->
    <path
        android:pathData="M54,26 L38,12 M54,26 L70,12"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Antenna Bulbs -->
    <path
        android:pathData="M38,12 A 2,2 0 1,1 38,11.9 M70,12 A 2,2 0 1,1 70,11.9"
        android:fillColor="#FFFFFF" />

    <!-- Inner screen playing triangle in high contrast deep forest black -->
    <path
        android:pathData="M46,40 L66,50 L46,60 Z"
        android:fillColor="#040F09" />
        
</vector>
